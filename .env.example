# Ara's model: served via Ollama Cloud through the OpenAI-compatible API.
# These are server-only. Never expose the key to the browser.

# Production (Ollama Cloud):
#   OLLAMA_BASE_URL=https://ollama.com/v1
#   OLLAMA_API_KEY=<your cloud key>
#   OLLAMA_MODEL=kimi-k2-thinking:cloud   # the exact Kimi cloud tag
#
# Local dev (Ollama running locally, key optional):
#   OLLAMA_BASE_URL=http://localhost:11434/v1
#   OLLAMA_MODEL=<a model you have pulled>

OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_API_KEY=
OLLAMA_MODEL=kimi-k2-thinking:cloud
